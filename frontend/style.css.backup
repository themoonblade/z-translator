:root {
    --primary-color: #4f46e5;
    --primary-hover: #4338ca;
    --bg-color: #f8fafc;
    --card-bg: #ffffff;
    --text-color: #1e293b;
    --text-muted: #64748b;
    --border-color: #e2e8f0;
    --help-bg: #eff6ff;
    --help-border: #bfdbfe;
    --shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Outfit', sans-serif;
}

body {
    background-color: var(--bg-color);
    color: var(--text-color);
    min-height: 100vh;
    margin: 0;
    padding-top: 80px;
}

border: 1px solid var(--border-color);
padding: 0.5rem 1rem;
border-radius: 0.5rem;
outline: none;
cursor: pointer;
transition: border-color 0.3s,
box-shadow 0.3s;
}

select:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}

.tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
}

.tab-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 0.75rem 1.5rem;
    font-size: 1.1rem;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
}

.tab-btn.active {
    color: var(--primary-color);
    border-bottom-color: var(--primary-color);
}

.tab-btn:hover:not(.active) {
    color: var(--text-color);
    background-color: rgba(79, 70, 229, 0.05);
}

.tab-content {
    display: none;
    animation: fadeIn 0.3s ease-in-out;
}

.tab-content.active {
    display: block;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }

}

.api-section h3 {
    color: var(--text-color);
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
}

.api-endpoint {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow);
}

.api-endpoint h4 {
    color: var(--text-color);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.method {
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
}

.method.get {
    background-color: #10b981;
    color: white;
}

.method.post {
    background-color: #3b82f6;
    color: white;
}

.api-endpoint p {
    color: var(--text-muted);
    margin-bottom: 1rem;
}

.api-endpoint ul {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
}

.api-endpoint code {
    background-color: rgba(79, 70, 229, 0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
}

.code-block {
    background-color: #1e293b;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
}

.code-block pre {
    margin: 0;
}

.code-block code {
    color: #e2e8f0;
    background: none;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
    line-height: 1.5;
}

.api-note {
    background-color: #fef3c7;
    border: 1px solid #fbbf24;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-top: 2rem;
}

.api-note h4 {
    color: #92400e;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.api-note ul {
    margin-left: 1.5rem;
    color: #78350f;
}

.api-note code {
    background-color: rgba(251, 191, 36, 0.2);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
}

/* Text Translation Styles */
.translation-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: start;
}

.input-panel,
.output-panel {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 500px;
}

.lang-select-container {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
}

textarea,
.output-box {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-color);
    font-size: 1.05rem;
    resize: none;
    outline: none;
    line-height: 1.6;
}

.output-box {
    overflow-y: auto;
    white-space: pre-wrap;
}

.char-count {
    text-align: right;
    font-size: 0.85rem;
    color: var(--text-muted);
}

.action-panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    height: 100%;
}

.primary-btn {
    background-color: var(--primary-color);
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.2s, box-shadow 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    box-shadow: var(--shadow);
}

.primary-btn:hover {
    background-color: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.primary-btn:disabled {
    background-color: var(--text-muted);
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.secondary-btn {
    background-color: #10b981;
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.2s, box-shadow 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    box-shadow: var(--shadow);
}

.secondary-btn:hover {
    cursor: pointer;
    font-size: 1.2rem;
    transition: color 0.3s;
    padding: 0.5rem;
}

.copy-btn:hover {
    color: var(--primary-color);
}

/* Translation Metrics */
.translation-metrics {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background-color: var(--help-bg);
    border: 1px solid var(--help-border);
    border-radius: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-color);
}

.translation-metrics i {
    color: var(--primary-color);
}

.translation-metrics .separator {
    color: var(--text-muted);
    margin: 0 0.25rem;
}

/* File Translation Styles */
.file-upload-container {
    margin-bottom: 2rem;
}

.upload-area {
    border: 2px dashed var(--border-color);
    border-radius: 1rem;
    padding: 4rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    background-color: var(--card-bg);
}

.upload-area:hover,
.upload-area.dragover {
    border-color: var(--primary-color);
    background-color: rgba(79, 70, 229, 0.05);
}

.upload-area i {
    font-size: 3rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
}

.upload-area h3 {
    margin-bottom: 0.5rem;
    color: var(--text-color);
}

.upload-area p {
    color: var(--text-muted);
}

.file-info {
    margin-top: 1rem;
    background-color: var(--card-bg);
    padding: 1rem;
    border-radius: 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow);
}

.file-info.hidden {
    display: none;
}

#remove-file {
    background: transparent;
    border: none;
    color: #ef4444;
    cursor: pointer;
    font-size: 1.2rem;
    transition: color 0.3s;
}

#remove-file:hover {
    color: #dc2626;
}

.file-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    background-color: var(--card-bg);
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow);
}

.lang-pair {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.lang-pair i {
    color: var(--text-muted);
}

.file-action-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.file-result {
    background-color: var(--card-bg);
    border-radius: 1rem;
    padding: 2rem;
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow);
}

.file-result.hidden {
    display: none;
}

.file-result h4 {
    margin-bottom: 1.5rem;
    color: var(--primary-color);
    font-size: 1.25rem;
}

.result-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
}

.original-preview,
.translated-preview {
    background-color: var(--bg-color);
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border-color);
}

.original-preview h5,
.translated-preview h5 {
    margin-bottom: 1rem;
    color: var(--text-muted);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
    font-weight: 600;
}

#file-original-text,
#file-translated-text {
    white-space: pre-wrap;
    max-height: 500px;
    overflow-y: auto;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-color);
}

/* Responsive */
@media (max-width: 768px) {
    .translation-grid {
        grid-template-columns: 1fr;
    }

    .action-panel {
        flex-direction: row;
        height: auto;
    }

    .result-content {
        grid-template-columns: 1fr;
    }

    .file-controls {
        flex-direction: column;
        gap: 1rem;
    }

    .file-action-buttons {
        width: 100%;
        flex-direction: column;
    }
}